# Anthropic API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# GitHub (for model discovery)
GITHUB_TOKEN=your_github_personal_access_token_here

# MLflow tracking
MLFLOW_TRACKING_URI=./mlruns

# Logging
LOG_LEVEL=INFO
LOG_DIR=./logs

# Model saving
MODEL_SAVE_DIR=./models/saved

# Computation
DEVICE=cuda
NUM_WORKERS=4
