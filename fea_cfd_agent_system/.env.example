# ── LLM Providers ─────────────────────────────────────────────────────────────
# OpenRouter (development agents: analyst, selector, iteration, architect, discovery)
# Sign up at https://openrouter.ai and set your key here.
# Works with Kilo AI — set this same key in Kilo's provider settings.
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=anthropic/claude-sonnet-4   # any OpenRouter model slug

# Anthropic (verifier only: code generation, physics certificate)
# Required even if using OpenRouter for dev agents.
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_VERIFIER_MODEL=claude-sonnet-4-20250514

# GitHub (for model discovery)
GITHUB_TOKEN=your_github_personal_access_token_here

# MLflow tracking
MLFLOW_TRACKING_URI=./mlruns

# Logging
LOG_LEVEL=INFO
LOG_DIR=./logs

# Model saving
MODEL_SAVE_DIR=./models/saved

# Computation
DEVICE=cuda
NUM_WORKERS=4
